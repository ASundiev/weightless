# --- SPA (Vite) ---
# Base URL of the deployed Deno Deploy project, e.g. https://weightless.deno.dev
VITE_FUNCTIONS_URL=

# Optional GitHub Pages subpath when hosted at /<repo>/; leave as "/" locally.
VITE_BASE_PATH=/

# --- Local Mac sync watcher (scripts/sync.ts) ---
# Folder on the Mac where Health Auto Export writes JSON exports.
HAE_WATCH_DIR=/Users/you/Library/Mobile Documents/iCloud~…~HealthAutoExport/Documents/Weightless
# Same URL as VITE_FUNCTIONS_URL, used by the watcher.
FUNCTIONS_URL=
# Bearer token shared by the SPA, the Mac watcher, and Claude's MCP connector.
WEIGHTLESS_TOKEN=

# --- Server / DB (for `db/migrate.ts` locally and for Deno Deploy runtime) ---
# Neon connection string. Prefer the POOLED one (includes "-pooler" in host).
# Example: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=
