# --- SPA (Vite) ---
# URL of the deployed Supabase Edge Functions, e.g.
#   https://abcxyz.supabase.co/functions/v1
VITE_FUNCTIONS_URL=

# Optional GitHub Pages subpath when hosted at /<repo>/; leave as "/" locally.
VITE_BASE_PATH=/

# --- Local Mac sync watcher (scripts/sync.ts) ---
# Folder on the Mac where Health Auto Export writes JSON exports.
HAE_WATCH_DIR=/Users/you/Library/Mobile Documents/iCloud~…~HealthAutoExport/Documents/Weightless
# Same URL as VITE_FUNCTIONS_URL, used by the watcher.
FUNCTIONS_URL=
# Bearer token that protects /ingest and /api and /mcp.
# Matches Supabase secret WEIGHTLESS_TOKEN.
WEIGHTLESS_TOKEN=
